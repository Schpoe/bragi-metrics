      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "jira-metrics-pg" },
          "format": "table",
          "rawSql": "SELECT key AS \"Key\", summary AS \"Summary\", issue_type AS \"Type\", priority AS \"Priority\", status AS \"Status\", COALESCE(assignee, 'Unassigned') AS \"Assignee\", TO_CHAR(created_at, 'YYYY-MM-DD') AS \"Created\", COALESCE((SELECT s.name FROM sprint_issues si JOIN sprints s ON s.id = si.sprint_id WHERE si.issue_key = issues.key AND si.removed_at IS NULL ORDER BY CASE s.state WHEN 'active' THEN 1 WHEN 'future' THEN 2 WHEN 'closed' THEN 3 END LIMIT 1), '—') AS \"Sprint\" FROM issues WHERE project_key IN ($project) AND issue_type NOT IN ('Epic','Sub-task') AND date_trunc('quarter', created_at) = '$quarter'::date AND has_qase_link = FALSE AND status IN ($status_filter) AND COALESCE((SELECT s.state FROM sprint_issues si JOIN sprints s ON s.id = si.sprint_id WHERE si.issue_key = issues.key AND si.removed_at IS NULL ORDER BY CASE s.state WHEN 'active' THEN 1 WHEN 'future' THEN 2 WHEN 'closed' THEN 3 END LIMIT 1), 'none') IN ($sprint_scope) ORDER BY created_at DESC",

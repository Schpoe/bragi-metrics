      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "pluginVersion": "11.1.0",
      "targets": [{ "datasource": { "type": "postgres", "uid": "jira-metrics-pg" }, "format": "table", "rawSql": "SELECT ROUND(AVG(EXTRACT(DAY FROM (i.resolved_at - i.created_at)))::numeric, 1) AS value FROM issues i WHERE i.project_key IN ($project) AND i.resolved_at IS NOT NULL AND i.key IN (SELECT issue_key FROM issue_fix_version_history WHERE fix_version = '$release' AND removed_at IS NULL)", "refId": "A" }],
      "title": "Avg Days to Resolution", "type": "stat"
    },

    {
      "datasource": { "type": "postgres", "uid": "jira-metrics-pg" },

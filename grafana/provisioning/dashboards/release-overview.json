      "pluginVersion": "11.1.0",
      "targets": [{ "datasource": { "type": "postgres", "uid": "jira-metrics-pg" }, "format": "table", "rawSql": "SELECT ROUND(100.0 * COUNT(*) FILTER (WHERE i.resolved_at IS NOT NULL) / NULLIF(COUNT(*), 0), 1) AS value FROM issues i WHERE i.project_key IN ($project) AND i.key IN (SELECT issue_key FROM issue_fix_version_history WHERE fix_version = '$release' AND removed_at IS NULL)", "refId": "A" }],

        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Key" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "targetBlank": true,
                    "title": "Open in Jira",
                    "url": "${jira_url}/browse/${__value.text}"

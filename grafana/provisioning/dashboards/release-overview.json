      "pluginVersion": "11.1.0",
      "targets": [{ "datasource": { "type": "postgres", "uid": "jira-metrics-pg" }, "format": "table", "rawSql": "SELECT COUNT(DISTINCT i.key) AS value FROM issues i WHERE i.project_key IN ($project) AND i.key IN (SELECT issue_key FROM issue_fix_version_history WHERE fix_version = '$release' AND removed_at IS NULL)", "refId": "A" }],
      "title": "Total Issues in Release", "type": "stat"

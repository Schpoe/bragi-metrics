    {
      "datasource": { "type": "postgres", "uid": "jira-metrics-pg" },
      "description": "Average days from creation to resolution for resolved issues.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" }, "decimals": 1, "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 20 }] },
          "unit": "d"

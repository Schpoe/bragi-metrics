      "description": "All issues in release. Sortable by any column.",
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "left", "cellOptions": { "type": "auto" }, "inspect": false },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Key" },
            "properties": [{ "id": "links", "value": [{ "targetBlank": true, "title": "Open in Jira", "url": "${jira_url}/browse/${__value.text}" }] }]
          },
          {
            "matcher": { "id": "byName", "options": "Type" },
            "properties": [
              { "id": "mappings", "value": [{ "type": "value", "options": { "Bug": { "color": "red", "index": 0, "text": "Bug" }, "Story": { "color": "green", "index": 1, "text": "Story" }, "Task": { "color": "blue", "index": 2, "text": "Task" }, "Improvement": { "color": "yellow", "index": 3, "text": "Improvement" } } }] },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              { "id": "mappings", "value": [{ "type": "value", "options": { "Done": { "color": "green", "index": 0 }, "In Progress": { "color": "yellow", "index": 1 }, "Blocked": { "color": "red", "index": 2 }, "Open": { "color": "text", "index": 3 }, "Backlog": { "color": "text", "index": 4 } } }] },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Priority" },
            "properties": [
              { "id": "mappings", "value": [{ "type": "value", "options": { "Blocker": { "color": "dark-red", "index": 0, "text": "Blocker" }, "Critical": { "color": "red", "index": 1, "text": "Critical" }, "High": { "color": "orange", "index": 2, "text": "High" }, "Medium": { "color": "yellow", "index": 3, "text": "Medium" }, "Low": { "color": "green", "index": 4, "text": "Low" } } }] },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          }
        ]

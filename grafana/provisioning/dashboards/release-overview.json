    {
      "datasource": { "type": "postgres", "uid": "jira-metrics-pg" },
      "description": "All issues in release. Sortable by any column.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "cellOptions": { "type": "auto" },
            "inspect": false

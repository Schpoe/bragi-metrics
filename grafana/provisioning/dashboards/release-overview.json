        ]
      },
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 20 },
      "id": 10,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Created" }]
      },
      "pluginVersion": "11.1.0",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "jira-metrics-pg" },
          "format": "table",
          "rawSql": "SELECT i.key AS \"Key\", i.summary AS \"Summary\", i.issue_type AS \"Type\", i.project_key AS \"Team\", COALESCE(array_to_string(i.components, ', '), '—') AS \"Component\", i.priority AS \"Priority\", i.status AS \"Status\", COALESCE(i.assignee, 'Unassigned') AS \"Assignee\", TO_CHAR(i.created_at, 'YYYY-MM-DD') AS \"Created\", CASE WHEN i.resolved_at IS NOT NULL THEN TO_CHAR(i.resolved_at, 'YYYY-MM-DD') ELSE '—' END AS \"Resolved\", CASE WHEN i.resolved_at IS NOT NULL THEN EXTRACT(DAY FROM (i.resolved_at - i.created_at))::int ELSE NULL END AS \"Days to Fix\" FROM issues i WHERE i.project_key IN ($project) AND i.key IN (SELECT issue_key FROM issue_fix_version_history WHERE release_name = '$release' AND removed_at IS NULL) ORDER BY i.created_at DESC",
          "refId": "A"
        }
      ],
      "title": "All Issues in Release",
      "type": "table"
    }
  ]
}
